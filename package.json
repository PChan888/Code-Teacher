{
  "name": "code-translator",
  "displayName": "Code Translator",
  "publisher": "PChan888",
  "description": "Explains C code line by line in plain English",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.106.0"
  },
  "categories": [
    "Education"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeTranslator.openPanel",
        "title": "Code Translator: Open Panel"
      }
    ],
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "codeTranslator",
          "title": "Code Translator",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "codeTranslator": [
        {
          "id": "codeTranslator.explainerView",
          "name": "Explanation",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Code Translator",
      "properties": {
        "codeTranslator.docsProvider": {
          "type": "string",
          "enum": [
            "cppreference",
            "geeksforgeeks"
          ],
          "default": "cppreference",
          "description": "Which site opens when clicking a documentation link in the Syntax Breakdown."
        },
        "codeTranslator.ai.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable the optional 'Deeper Dive' AI explanation using a local Ollama model. Requires Ollama running on localhost \u2014 the extension is fully functional without it, and this makes zero network calls unless enabled."
        },
        "codeTranslator.ai.model": {
          "type": "string",
          "default": "llama3.2",
          "description": "Ollama model name to use for 'Deeper Dive' explanations."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.10"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/PChan888/Code-Teacher.git"
  },
  "license": "MIT"
}
